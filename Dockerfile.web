# CLARIS demo web app image (the batch agent lives in the root Dockerfile).
# Serves the FastAPI + WebSocket surface (claris.api). The Next.js frontend is
# built and served separately (see docker-compose.yml).

FROM python:3.11-slim AS runtime
COPY --from=ghcr.io/astral-sh/uv:latest /uv /usr/local/bin/uv
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        ffmpeg \
        build-essential \
        gcc \
        g++ \
        libgl1 \
        libglib2.0-0 \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app
COPY pyproject.toml uv.lock README.md ./
COPY claris ./claris
# Installs from the locked deps, which now include python-multipart (needed by /upload).
# The websockets library for /ws is already pulled in by uvicorn[standard].
RUN uv sync --locked --no-dev

ENV PATH="/app/.venv/bin:$PATH" \
    PYTHONUNBUFFERED=1
EXPOSE 8000
# Bind the platform-provided $PORT (Railway/Render inject it) with a local fallback, so the
# service is reachable and its health check passes. Shell form is required for $PORT to expand.
# Target the module-level `app` (not the factory) so any uvicorn version / auto-detected
# command starts a real ASGI app rather than calling the factory per request (a 502 trap).
CMD ["sh", "-c", "uvicorn claris.api.main:app --host 0.0.0.0 --port ${PORT:-8000}"]
